{
  "name": "milpa/ai-gateway",
  "description": "Dual-provider LLM gateway for the Milpa PHP framework: OpenAI + Anthropic chat-completions client with tool-call format translation, an agentic tool-use loop, and a ToolRegistry facade for LLM/MCP exposure.",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.3",
    "milpa/core": "^0.4",
    "milpa/tool-runtime": "^0.4",
    "guzzlehttp/guzzle": "^7.10",
    "guzzlehttp/psr7": "^2.7",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^2.0",
    "psr/log": "^3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpdoc-parser": "^2.3",
    "friendsofphp/php-cs-fixer": "^3.65"
  },
  "autoload": {
    "psr-4": {
      "Milpa\\AiGateway\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Milpa\\AiGateway\\Tests\\": "tests/",
      "Milpa\\Docs\\": "vendor/milpa/core/tools/gen-docs/"
    }
  }
}
